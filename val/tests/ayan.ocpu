start:
    lda #$0A
    tax
    inx
    inx

    lda #$03
    tay

    lda $0080
    adc $0081
    sta $00A0

    sbc $0082
    sta $00A1

    lda $0083
    and $0084
    beq zero_case

    lda #$FF
    jmp fail

zero_case:
    lda $0085
    ora $0086
    eor $0087
    sta $00A2

    lda #$08
    asl
    asl
    lsr
    sta $00A3

    lda #$33
    pha

    lda #$77
    pha

    pla
    sta $00A4

    pla
    sta $00A5

    clc
    bcc branch_ok

fail:
    lda #$EE
    sta $00FF
    jmp fail

branch_ok:
    sec
    bcs carry_ok

    jmp fail

carry_ok:
    lda #$99
    sta $00B0

    lda #$42
    sta $00B1

    lda #$AB
    tax
    txa
    tay
    tya

done:
    jmp done

    .org $0080
    .byte $12
    .byte $05
    .byte $02
    .byte $F0
    .byte $0F
    .byte $55
    .byte $0A
    .byte $FF
